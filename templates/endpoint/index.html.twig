 <h1>Silver Company! ✅</h1></section>
 <br>
 <section id="section-body" name="section-body" class="section-body">

    <div class="container">
        <table id="example" class="table table-striped table-bordered dt-responsive nowrap" style="width:100%">
            <thead>
                <tr>
                    <th>nombre 1</th>
