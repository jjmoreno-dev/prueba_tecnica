<script type="text/javascript">
        $(document).ready(function () {
            //$('#example').DataTable();
            $.ajax({
                "url": "./api",
                "type": "GET",
                "datatype": 'json',
                 
                "success": function (data) {
                    $('#example').DataTable({
                        data: data,
                //"paging": false,
                        columns: [
                            { 'data': 'id' },
                            { 'data': 'name' },
                            { 'data': 'acronym' },
                           
                        ],
                        language: {
                processing: "Procesando...",
                search: "<span class='badge'>Buscar</span>",
                lengthMenu: "Mostrar _MENU_ Elementos",
                info: "Mostrando _START_ de _END_ de _TOTAL_ Registro",
                infoEmpty: "Ningun elemento encontrado",
                infoFiltered: "(Total _MAX_ Registrados)",
                //  infoPostFix:    "",
                // loadingRecords: "Chargement en cours...",
                zeroRecords: "No existen elementos referentes a la busqueda",
                emptyTable: "Aun no se a efectuado ningun registro",
                paginate: {
                    first: "Primer",
                    previous: "Anterior",
                    next: "Siguiente",
                    last: "Ultimo"
                },
            },
                    });
                }
            });
        });
